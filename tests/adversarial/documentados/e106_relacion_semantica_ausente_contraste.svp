-- ================================================================
-- e106_relacion_semantica_ausente_contraste.svp
-- Propósito: sonda documentada del contraste fino sobre E106.
-- La IR v0.2 y el catálogo efectivo coinciden en MissingSemanticRelation.
-- En la superficie actual del frontend, un graph con relation no declarada
-- cae en E006 por referencia ausente, no en E106.
-- ================================================================

codomain K3 = { APTO, NO_APTO, INDETERMINADO };

output_semantics SemK3 {
  APTO -> "Favorable";
  NO_APTO -> "Desfavorable";
  INDETERMINADO -> "Indeterminado";
}

cellspec C1 {
  b: 3;
  codomain: K3;
  semantics: SemK3;
  role: Base;
}

coupledspec CC1 {
  cell: C1;
  bridges: [5];
}

graph G_contraste {
  nodes: [CC1];
  edges: [];
  relation: R_ausente;
  regime: Simple;
}
