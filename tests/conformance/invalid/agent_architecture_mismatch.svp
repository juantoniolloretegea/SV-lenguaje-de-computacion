-- agent_architecture_mismatch.svp — agent con arquitectura incoherente con su Domain

capture_spec Cap1 {
  parameter_id: 1;
  observation_domain: DomObs1;
  observation_space: ObsEsp1;
  failure_symbol: Bottom;
  mapping: MapCap1;
}

admissibility_spec Adm1 {
  parameter_id: 1;
  states: {Ok, Degraded, Failed, U};
  rule: ReglaAdm1;
}

ternarizer Ter1 {
  observation_space: ObsEsp1;
  partition_zero: Zona0;
  partition_one: Zona1;
  partition_u: ZonaU;
  mapping: MapTer1;
}

horizon H1 {
  architecture: ArchH1;
  events: [Ev1];
}

domain D1 {
  parameters: [P1];
  interface: I1;
  horizon: H1;
  capture_specs: [Cap1];
  admissibility_specs: [Adm1];
  ternarizers: [Ter1];
  exogeneity_mask: Exo1;
  silent_u: SU1;
  transduction_policy: TP1;
  u_policy: UP1;
  closure_criterion: CC1;
}

agent AG_bad {
  architecture: ArchDistinta;
  domain: D1;
  query_engine: QE1;
}
