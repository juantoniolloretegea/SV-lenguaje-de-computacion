{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inventario de publicaciones del Sistema Vectorial SV",
  "type": "object",
  "required": [
    "fecha_publicacion",
    "titulo_canonico",
    "titulo_breve",
    "doi_citacion_preferente",
    "enlace_principal",
    "enlaces_espejo",
    "coleccion_principal",
    "colecciones_relacionadas",
    "dominio_sv",
    "funcion_dentro_del_sv",
    "relacion_con_otras_publicaciones",
    "estado_editorial",
    "fuente_verificada",
    "observaciones_de_custodia"
  ],
  "properties": {
    "fecha_publicacion": {
      "type": "string",
      "description": "Fecha de publicación o depósito en formato AAAA-MM-DD cuando sea verificable."
    },
    "titulo_canonico": {
      "type": "string"
    },
    "titulo_breve": {
      "type": "string"
    },
    "doi_citacion_preferente": {
      "type": "string"
    },
    "enlace_principal": {
      "type": "string"
    },
    "enlaces_espejo": {
      "type": "string"
    },
    "coleccion_principal": {
      "type": "string"
    },
    "colecciones_relacionadas": {
      "type": "string"
    },
    "dominio_sv": {
      "type": "string"
    },
    "funcion_dentro_del_sv": {
      "type": "string",
      "description": "Explicación material de la función que cumple la publicación dentro del Sistema Vectorial SV; no debe ser sinopsis débil ni frase promocional."
    },
    "relacion_con_otras_publicaciones": {
      "type": "string"
    },
    "estado_editorial": {
      "type": "string"
    },
    "fuente_verificada": {
      "type": "string"
    },
    "observaciones_de_custodia": {
      "type": "string"
    }
  },
  "description": "Esquema del inventario de publicaciones propias del Sistema Vectorial SV o antecedentes técnicos directos con DOI verificable."
}